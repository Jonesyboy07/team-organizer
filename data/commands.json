{
    "sections": [
        {
            "name": "Setup",
            "commands": [
                {
                    "name": "setup",
                    "description": "Set up the bot in this server.",
                    "usage": "/setup command_channel:<channel> admin_role:<role> update_logs:<channel> bot_logs:<channel>",
                    "admin_required": true
                },
                {
                    "name": "addbotchannel",
                    "description": "Add a bot command channel.",
                    "usage": "/addbotchannel channel:<channel>",
                    "admin_required": true
                },
                {
                    "name": "removebotchannel",
                    "description": "Remove a bot command channel.",
                    "usage": "/removebotchannel channel:<channel>",
                    "admin_required": true
                },
                {
                    "name": "addadminrole",
                    "description": "Add an admin role.",
                    "usage": "/addadminrole role:<role>",
                    "admin_required": true
                },
                {
                    "name": "removeadminrole",
                    "description": "Remove an admin role.",
                    "usage": "/removeadminrole role:<role>",
                    "admin_required": true
                },
                {
                    "name": "listbotchannels",
                    "description": "List all configured bot channels.",
                    "usage": "/listbotchannels",
                    "admin_required": true
                },
                {
                    "name": "listadminroles",
                    "description": "List all configured admin roles.",
                    "usage": "/listadminroles",
                    "admin_required": true
                },
                {
                    "name": "setbotlogchannel",
                    "description": "Set or change the bot logging channel.",
                    "usage": "/setbotlogchannel channel:<channel>",
                    "admin_required": true
                }
            ]
        },
        {
            "name": "General",
            "commands": [

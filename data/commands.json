        {
            "name": "Teams",
            "commands": [
                {
                    "name": "my_teams",
                    "description": "Show teams you are part of or captain of.",
                    "usage": "/my_teams",
                    "admin_required": false
                },
                {
                    "name": "create_team",
                    "description": "Create a new team",
                    "usage": "/create_team team_name:<text> game:<text> team_captain:<member> team_role:<role> team_schedule_channel:<channel> team_request_channel:<channel> timezone:<text>",
                    "admin_required": true
                },
                {
                    "name": "list_teams",
                    "description": "List all teams in this server.",
                    "usage": "/list_teams [per_page:<number>]",
                    "admin_required": true
                },
                {
                    "name": "delete_team",
                    "description": "Delete a team from this server.",
                    "usage": "/delete_team",
                    "admin_required": true
                },
                {
                    "name": "modify_team",
                    "description": "Modify a team's details.",
                    "usage": "/modify_team",
                    "admin_required": true
                },
                {
                    "name": "request_match",
                    "description": "Request a match from another team.",
